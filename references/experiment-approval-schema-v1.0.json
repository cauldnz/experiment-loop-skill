{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/experiment-loop/experiment-approval-schema-v1.0.json",
  "title": "Experiment Setup Approval v1.0",
  "type": "object",
  "required": [
    "schema_version",
    "experiment_id",
    "brief_revision",
    "brief_sha256",
    "prompt_sha256",
    "status",
    "approved_at",
    "approval_source"
  ],
  "properties": {
    "schema_version": {"const": "1.0"},
    "experiment_id": {"type": "string", "minLength": 1},
    "brief_revision": {"type": "integer", "minimum": 1},
    "brief_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "prompt_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "status": {"const": "approved"},
    "approved_at": {"type": "string", "format": "date-time"},
    "approval_source": {"const": "explicit_human_confirmation"},
    "notes": {"type": "string"}
  },
  "additionalProperties": false
}
