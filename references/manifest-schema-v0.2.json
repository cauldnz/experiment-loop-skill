{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/experiment-loop/manifest-schema-v0.2.json",
  "title": "Experiment Loop Manifest",
  "type": "object",
  "required": ["schema_version", "experiment_id", "title", "goal", "tracks", "iterations"],
  "properties": {
    "schema_version": {"const": "0.2"},
    "experiment_id": {"type": "string"},
    "title": {"type": "string"},
    "goal": {"type": "string"},
    "created_at": {"type": "string"},
    "budget": {
      "type": "object",
      "properties": {
        "max_iters": {"type": ["integer", "null"]},
        "patience": {"type": ["integer", "null"]},
        "cost_limit": {"type": ["number", "null"]},
        "wall_time_limit_sec": {"type": ["integer", "null"]}
      },
      "additionalProperties": true
    },
    "artifact_scope": {"type": "object"},
    "scorecard": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "label", "weight"],
        "properties": {
          "id": {"type": "string"},
          "label": {"type": "string"},
          "weight": {"type": "number"}
        },
        "additionalProperties": true
      }
    },
    "scorers": {"type": "array", "items": {"type": "object"}},
    "judge_panels": {"type": "array", "items": {"type": "object"}},
    "governance": {"type": "object"},
    "tracks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "label", "hypothesis"],
        "properties": {
          "id": {"type": "string"},
          "label": {"type": "string"},
          "hypothesis": {"type": "string"},
          "final_decision": {"type": "string"},
          "finals": {"type": "array", "items": {"$ref": "#/$defs/artifact"}}
        },
        "additionalProperties": true
      }
    },
    "iterations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "track_id", "hypothesis", "commands", "artifacts", "scores", "decision"],
        "properties": {
          "id": {"type": "string"},
          "track_id": {"type": "string"},
          "parent_id": {"type": ["string", "null"]},
          "hypothesis": {"type": "string"},
          "commands": {"type": "object"},
          "artifacts": {"type": "array", "items": {"$ref": "#/$defs/artifact"}},
          "scores": {"type": "array", "items": {"type": "object"}},
          "prompt": {
            "type": "object",
            "properties": {
              "track_prompt": {"type": "string"},
              "input_feedback": {"type": "string"},
              "judge_feedback": {"type": "string"},
              "next_prompt": {"type": "string"}
            },
            "additionalProperties": true
          },
          "quality_gates": {"type": "object"},
          "layout_quality": {"type": "object"},
          "changed_files": {"type": "array", "items": {"type": "string"}},
          "lesson": {"type": "object"},
          "decision": {
            "type": "string",
            "enum": ["new_best", "reject", "keep_for_synthesis", "needs_human_review", "failed"]
          },
          "stop_reason": {"type": ["string", "null"]}
        },
        "additionalProperties": true
      }
    },
    "best": {"type": ["object", "null"]},
    "rules": {"type": "array"},
    "synthesis": {"type": "string"}
  },
  "$defs": {
    "artifact": {
      "type": "object",
      "required": ["kind", "label", "path"],
      "properties": {
        "kind": {"type": "string"},
        "label": {"type": "string"},
        "path": {"type": "string"},
        "contact_path": {"type": "string"},
        "sha256": {"type": "string"}
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
