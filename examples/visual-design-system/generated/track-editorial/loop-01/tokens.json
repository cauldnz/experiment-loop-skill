{
  "system": "loop-lab-editorial-card",
  "loop": "loop-01",
  "description": "Editorial-typography event card system for Loop Lab workshops. Print-inspired grid with kicker, rule lines, three-column metadata, and footer CTA.",
  "color": {
    "paper": { "value": "#F8F4EC", "role": "canvas background" },
    "ink": { "value": "#1B1F33", "role": "primary text, title, values, logo mark, CTA fill, frame stroke" },
    "ink.muted": {
      "value": "#A39C8C",
      "role": "secondary/caption text: metadata labels, edition tag, microcopy",
      "known_issue": "Fails WCAG AA contrast against paper at loop-01 (measured 2.49:1, see layout-metrics.json). Carried into loop-02 as the primary fix target."
    },
    "accent": { "value": "#B5432E", "role": "kicker text, decorative brand rhythm marks" },
    "line.default": { "value": "#C9C2B4", "role": "decorative rule lines and column dividers (non-text, not subject to text contrast gate)" },
    "on-ink": { "value": "#FFFFFF", "role": "text on filled ink surfaces (CTA button)" }
  },
  "typography": {
    "font.serif": { "value": "Georgia, 'Times New Roman', serif", "role": "title, metadata values, microcopy" },
    "font.sans": { "value": "'Segoe UI', Arial, Helvetica, sans-serif", "role": "kicker, labels, edition tag, CTA, logo mark" },
    "scale": {
      "title": { "size": 64, "weight": 700, "lineHeight": 76, "font": "font.serif" },
      "value": { "size": 30, "weight": 700, "font": "font.serif" },
      "label": { "size": 16, "weight": 700, "letterSpacing": 2, "font": "font.sans", "case": "uppercase" },
      "kicker": { "size": 18, "weight": 700, "letterSpacing": 2.5, "font": "font.sans", "case": "uppercase" },
      "eyebrow-tag": { "size": 16, "weight": 400, "letterSpacing": 1, "font": "font.sans", "case": "uppercase" },
      "cta": { "size": 22, "weight": 700, "letterSpacing": 1.5, "font": "font.sans", "case": "uppercase" },
      "microcopy": { "size": 16, "weight": 400, "style": "italic", "font": "font.serif" },
      "logo-mark": { "size": 18, "weight": 700, "font": "font.sans" }
    },
    "minimumFontSizePx": 16
  },
  "spacing": {
    "canvas": { "width": 1200, "height": 630 },
    "frameInset": 24,
    "contentMargin": { "left": 80, "right": 80, "top": 56, "bottom": 24 },
    "rowGap.headerToTitle": 30,
    "rowGap.titleToRule": 26,
    "rowGap.ruleToLabels": 26.4,
    "rowGap.labelsToValues": 23.2,
    "rowGap.valuesToBottomRule": 43.75,
    "rowGap.bottomRuleToFooter": 19.25
  },
  "radius": {
    "logoMark": 6,
    "ctaButton": 6
  },
  "layout": {
    "grid": "3-column metadata row over full-bleed frame",
    "columns": [
      { "name": "date", "x": 80, "width": 340 },
      { "name": "time", "x": 440, "width": 340 },
      { "name": "venue", "x": 800, "width": 320 }
    ],
    "dividerX": [420, 780]
  },
  "components": {
    "logoMark": { "shape": "rounded-rect", "size": [40, 40], "fill": "ink", "label": "LL" },
    "kicker": { "position": "top-left, after logo mark", "color": "accent" },
    "editionTag": { "position": "top-right", "color": "ink.muted" },
    "headerRule": { "stroke": "line.default", "strokeWidth": 1.5 },
    "titleBlock": { "maxLines": 2, "color": "ink" },
    "metadataRow": { "labelColor": "ink.muted", "valueColor": "ink", "dividerStroke": "line.default" },
    "ctaButton": {
      "fill": "ink",
      "textColor": "on-ink",
      "size": [260, 64],
      "position": "bottom-right",
      "label": "REGISTER NOW \u2192"
    },
    "microcopy": { "position": "bottom-left, aligned to CTA baseline row", "color": "ink.muted" },
    "brandRhythmMark": { "shape": "3 small squares", "size": 6, "gap": 15, "color": "accent", "position": "bottom-center, decorative" }
  }
}
