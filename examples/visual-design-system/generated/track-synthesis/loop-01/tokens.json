{
  "schema": "loop-lab-event-card-tokens/1.0",
  "iteration": "synthesis-01",
  "description": "A reusable editorial-plus-signal-path event-card system. Display cards reserve a protected editorial zone and a separate routing module; compact cards stack the same components.",
  "source_lineage": ["editorial-02", "generative-02"],
  "color": {
    "surface.paper": {"value": "#F6F1E8", "role": "display and compact card background"},
    "surface.sheet": {"value": "#0F1426", "role": "system-sheet background"},
    "surface.module": {"value": "#171C32", "role": "signal-routing panel"},
    "text.primary": {"value": "#171C32", "role": "title and metadata values", "contrast_on_paper": 14.95},
    "text.secondary": {"value": "#5E5D58", "role": "labels and supporting copy", "contrast_on_paper": 5.87},
    "text.inverse": {"value": "#FFFFFF", "role": "text on dark or accent surfaces"},
    "text.moduleMuted": {"value": "#BFD9DD", "role": "small labels on module surface", "contrast_on_module": 11.36},
    "border.neutral": {"value": "#BDB6AA", "role": "editorial rules"},
    "border.module": {"value": "#39405A", "role": "module rules"},
    "accent.coral": {"value": "#9F3424", "role": "in-person state, title rail, badges", "contrast_on_paper": 6.24, "white_text_contrast": 7.02},
    "accent.teal": {"value": "#006E70", "role": "hybrid state", "white_text_contrast": 6.06},
    "accent.indigo": {"value": "#4452B8", "role": "virtual state", "white_text_contrast": 6.68},
    "signal.cyan": {"value": "#2CB8B8", "role": "decorative primary route"},
    "signal.indigo": {"value": "#5965D8", "role": "decorative phase route"},
    "signal.coral": {"value": "#D65A42", "role": "decorative transfer route"},
    "action.default": {"value": "#173B57", "role": "CTA surface", "white_text_contrast": 11.67},
    "action.hover": {"value": "#0F2B43", "role": "CTA hover surface", "white_text_contrast": 14.51},
    "action.disabled": {"value": "#6D727E", "role": "disabled surface", "white_text_contrast": 4.82}
  },
  "typography": {
    "font.display": {"value": "Georgia, 'Times New Roman', serif", "external_asset_required": false},
    "font.ui": {"value": "'Segoe UI', Arial, Helvetica, sans-serif", "external_asset_required": false},
    "scale": {
      "display.title": {"font": "font.display", "size": 60, "lineHeight": 70, "weight": 700, "maxLines": 2},
      "display.value": {"font": "font.display", "size": 22, "lineHeight": 28, "weight": 700},
      "display.body": {"font": "font.display", "size": 16, "lineHeight": 22, "weight": 400},
      "display.label": {"font": "font.ui", "size": 14, "lineHeight": 18, "weight": 700, "letterSpacing": 1.8, "case": "uppercase"},
      "display.cta": {"font": "font.ui", "size": 18, "lineHeight": 22, "weight": 700, "letterSpacing": 1.4},
      "compact.title": {"font": "font.display", "size": 27, "lineHeight": 35, "weight": 700, "maxLines": 2},
      "compact.value": {"font": "font.display", "size": 15, "lineHeight": 20, "weight": 700},
      "compact.label": {"font": "font.ui", "size": 13, "lineHeight": 17, "weight": 700},
      "compact.cta": {"font": "font.ui", "size": 14, "lineHeight": 18, "weight": 700}
    },
    "minimumFontSizePx": {"display": 14, "compact": 13}
  },
  "spacing": {
    "unit": 4,
    "scale": {"1": 4, "2": 8, "3": 12, "4": 16, "5": 20, "6": 24, "8": 32, "10": 40, "12": 48, "16": 64, "18": 72},
    "display": {
      "frameInset": 24,
      "contentLeft": 72,
      "contentRight": 72,
      "zoneGutter": 80,
      "headerToTitle": 30,
      "titleToMetadata": 70,
      "metadataToFooter": 24
    },
    "compact": {"outer": 12, "inner": 12, "sectionGap": 20}
  },
  "radii": {
    "small": 6,
    "button": 8,
    "compactCard": 16,
    "module": 24,
    "pill": 999
  },
  "layout": {
    "canvas": {"width": 1200, "height": 630, "viewBox": "0 0 1200 630"},
    "display": {
      "frame": {"x": 24, "y": 24, "width": 1152, "height": 582},
      "editorialZone": {"x": 72, "y": 48, "width": 608, "height": 534},
      "signalZone": {"x": 760, "y": 48, "width": 368, "height": 534},
      "protectedGutter": {"x": 680, "y": 48, "width": 80, "height": 534},
      "titleSafeZoneRule": "rendered title bbox right edge must be <=696, leaving >=64px to signalZone.x",
      "metadataColumns": [
        {"id": "date", "x": 72, "width": 206},
        {"id": "time", "x": 292, "width": 206},
        {"id": "venue", "x": 512, "width": 168}
      ]
    },
    "compact": {
      "sheetCanvas": {"width": 1200, "height": 630},
      "card": {"width": 352, "height": 530},
      "responsivePattern": "stacked editorial header/title/metadata, then signal module and CTA"
    }
  },
  "components": {
    "logoMark": {"displaySize": [44, 44], "compactSize": [34, 34], "fill": "surface.module"},
    "titleRail": {"displaySize": [6, 136], "compactSize": [5, 74], "fill": "variant.accent"},
    "formatBadge": {
      "shape": "pill",
      "displaySize": [136, 32],
      "compactSize": [82, 28],
      "fill": "variant.accent",
      "text": "text.inverse",
      "labelBudget": {"displayCharacters": 12, "compactCharacters": 9}
    },
    "metadataRow": {
      "labels": ["DATE", "TIME", "VENUE"],
      "labelColor": "text.secondary",
      "valueColor": "text.primary",
      "displayDividers": true
    },
    "signalModule": {
      "surface": "surface.module",
      "displaySize": [368, 534],
      "compactSize": [304, 146],
      "routes": ["signal.cyan", "signal.indigo", "signal.coral"],
      "decorative": true,
      "mustNotEnter": "layout.display.editorialZone"
    },
    "cta": {
      "displaySize": [244, 60],
      "compactSize": [176, 52],
      "radius": "radii.button",
      "states": {
        "default": {"fill": "action.default", "text": "text.inverse", "contrast": 11.67},
        "hover": {"fill": "action.hover", "text": "text.inverse", "contrast": 14.51},
        "focusVisible": {"outline": "3px solid #9F3424", "outlineOffset": 3},
        "disabled": {"fill": "action.disabled", "text": "text.inverse", "contrast": 4.82, "opacity": 0.72}
      }
    }
  },
  "contentConstraints": {
    "displayTitle": {"maxLines": 2, "estimatedMaxCharactersPerLine": 17, "metric": "0.58 × font-size × characters"},
    "compactTitle": {"maxLines": 2, "estimatedMaxCharactersPerLine": 18},
    "venue": {"displayMaxCharacters": 12, "compactMaxCharacters": 11},
    "badge": {"displayMaxCharacters": 12, "compactMaxCharacters": 9}
  },
  "eventVariants": {
    "in-person": {
      "accent": "accent.coral",
      "workshop": "021",
      "title": ["DESIGNING WITH", "FEEDBACK LOOPS"],
      "date": "OCT 22, 2026",
      "time": "09:30–12:30",
      "venue": "STUDIO B",
      "format": "IN PERSON",
      "capacity": "40 SEATS",
      "routingPattern": "primary-loop"
    },
    "hybrid": {
      "accent": "accent.teal",
      "workshop": "022",
      "title": ["PROTOTYPING", "IN PUBLIC"],
      "date": "NOV 03, 2026",
      "time": "13:00–16:00",
      "venue": "HUB A + WEB",
      "format": "HYBRID",
      "capacity": "60 SEATS",
      "routingPattern": "paired-loop"
    },
    "virtual": {
      "accent": "accent.indigo",
      "workshop": "023",
      "title": ["DISTRIBUTED", "DECISION SYSTEMS"],
      "date": "DEC 11, 2026",
      "time": "16:00–18:00",
      "venue": "ONLINE",
      "format": "VIRTUAL",
      "capacity": "OPEN ACCESS",
      "routingPattern": "phase-loop"
    }
  }
}
