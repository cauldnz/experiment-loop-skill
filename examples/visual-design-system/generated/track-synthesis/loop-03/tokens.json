    },
    "accent.indigo": {
      "value": "#4452B8",
      "role": "virtual",
      "contrast_on_paper": 5.94,
      "white_text_contrast": 6.68
    },
    "signal.cyan": {
      "value": "#2CB8B8",
      "role": "decorative primary route"
    },
    "signal.indigo": {
      "value": "#5965D8",
      "role": "decorative phase route"
    },
    "signal.coral": {
      "value": "#D65A42",
      "role": "decorative transfer route"
    },
    "action.default": {
      "value": "#173B57",
      "role": "CTA surface",
      "white_text_contrast": 11.67
    },
    "action.hover": {
      "value": "#0F2B43",
      "role": "CTA hover surface",
      "white_text_contrast": 14.51
    },
    "action.disabled": {
      "value": "#6D727E",
      "role": "disabled surface",
      "white_text_contrast": 4.82
    }
  },
  "typography": {
    "font.display": {
      "value": "Georgia, 'Times New Roman', serif",
      "external_asset_required": false
    },
    "font.ui": {
      "value": "'Segoe UI', Arial, Helvetica, sans-serif",
      "external_asset_required": false
    },
    "scale": {
      "display.title": {
        "font": "font.display",
        "size": 60,
        "lineHeight": 70,
        "weight": 700,
        "maxLines": 2
      },
      "display.titleDense": {
        "font": "font.display",
        "size": 48,
        "lineHeight": 58,
        "weight": 700,
        "maxLines": 3
      },
      "display.value": {
        "font": "font.display",
        "size": 22,
        "lineHeight": 28,
        "weight": 700
      },
      "display.valueDense": {
        "font": "font.display",
        "size": 20,
        "lineHeight": 26,
        "weight": 700
      },
      "display.body": {
        "font": "font.display",
        "size": 16,
        "lineHeight": 22,
        "weight": 400
      },
      "display.label": {
        "font": "font.ui",
        "size": 14,
        "lineHeight": 18,
        "weight": 700,
        "letterSpacing": 1.8,
        "case": "uppercase"
      },
      "display.cta": {
        "font": "font.ui",
        "size": 18,
        "lineHeight": 22,
        "weight": 700,
        "letterSpacing": 1.4
      },
      "compact.title": {
        "font": "font.display",
        "size": 27,
        "lineHeight": 35,
        "weight": 700,
        "maxLines": 2
      },
      "compact.titleDense": {
        "font": "font.display",
        "size": 22,
        "lineHeight": 27,
        "weight": 700,
        "maxLines": 3
      },
      "compact.value": {
        "font": "font.display",
        "size": 15,
        "lineHeight": 20,
        "weight": 700
      },
      "compact.label": {
        "font": "font.ui",
        "size": 13,
        "lineHeight": 17,
        "weight": 700
      },
      "compact.cta": {
        "font": "font.ui",
        "size": 14,
        "lineHeight": 18,
        "weight": 700
      }
    },
    "minimumFontSizePx": {
      "display": 14,
      "compact": 13
    }
  },
  "spacing": {
    "unit": 4,
    "scale": {
      "1": 4,
      "2": 8,
      "3": 12,
      "4": 16,
      "5": 20,
      "6": 24,
      "7": 28,
      "8": 32,
      "10": 40,
      "12": 48,
      "14": 56,
      "16": 64,
      "18": 72
    },
    "display": {
      "frameInset": 24,
      "contentLeft": 72,
      "contentRight": 72,
      "zoneGutter": 72,
      "denseTitleToMetadata": 16,
      "metadataRowGap": 18,
      "metadataToFooter": 22
    },
    "compact": {
      "outer": 12,
      "inner": 12,
      "metadataLabelToValue": 8,
      "metadataRowGap": 17,
      "venueToModule": 18
    }
  },
  "radii": {
    "small": 6,
    "button": 8,
    "compactCard": 16,
    "module": 24,
    "pill": 999
  },
  "layout": {
    "canvas": {
      "width": 1200,
      "height": 630,
      "viewBox": "0 0 1200 630"
    },
    "display": {
      "frame": {
        "x": 24,
        "y": 24,
        "width": 1152,
        "height": 582
      },
      "editorialZone": {
        "x": 72,
        "y": 48,
        "width": 608,
        "height": 534
      },
      "signalZone": {
        "x": 752,
        "y": 48,
        "width": 376,
        "height": 534
      },
      "protectedGutter": {
        "x": 680,
        "y": 48,
        "width": 72,
        "height": 534
      },
      "titleSafeZoneRule": "rendered title bbox right edge must be <=688, leaving >=64px to signalZone.x",
      "metadataModes": {
        "standard": "three columns when each value fits its measured column",
        "wideVenue": "DATE/TIME in paired first row; VENUE full-width on second row"
      }
    },
    "compact": {
      "sheetCanvas": {
        "width": 1200,
        "height": 630
      },
      "card": {
        "width": 352,
        "height": 530
      },
      "contentWidth": 304,
      "metadata": {
        "firstRow": [
          {
            "id": "date",
            "xOffset": 0,
            "width": 112
          },
          {
            "id": "time",
            "xOffset": 124,
            "width": 180
          }
        ],
        "secondRow": [
          {
            "id": "venue",
            "xOffset": 0,
            "width": 304
          }
        ],
        "overflowPolicy": "wrap venue to a second line before reducing type below 13px"
      }
    }
  },
  "components": {
    "logoMark": {
      "displaySize": [
        44,
        44
      ],
      "compactSize": [
        34,
        34
      ],
      "fill": "surface.module"
    },
    "titleRail": {
      "displayStandardSize": [
        6,
        136
      ],
      "displayDenseSize": [
        6,
        172
      ],
      "compactDenseSize": [
        5,
        80
      ],
      "fill": "variant.accent"
    },
    "formatBadge": {
      "shape": "pill",
      "height": {
        "display": 32,
        "compact": 28
      },
      "horizontalPadding": {
        "display": 16,
        "compact": 12
      },
      "minimumWidth": {
        "display": 96,
        "compact": 82
      },
      "maximumWidth": {
        "display": 184,
        "compact": 144
      },
      "widthRule": "clamp(minimumWidth, measuredLabelWidth + 2×horizontalPadding, maximumWidth)",
      "overflowPolicy": "use concise localized label or two-line badge; never clip",
      "fill": "variant.accent",
      "text": "text.inverse"
    },
    "metadataGrid": {
      "labels": [
        "DATE",
        "TIME",
        "VENUE"
      ],
      "labelColor": "text.secondary",
      "valueColor": "text.primary",
      "selectionRule": "choose wideVenue mode when any measured value exceeds its standard column width",
      "compactMode": "DATE/TIME paired; VENUE full-width"
    },
    "signalModule": {
      "surface": "surface.module",
      "displaySize": [
        376,
        534
      ],
      "compactSize": [
        304,
        124
      ],
      "routes": [
        "signal.cyan",
        "signal.indigo",
        "signal.coral"
      ],
      "decorative": true,
      "mustNotEnter": "layout.display.editorialZone"
    },
    "cta": {
      "displaySize": [
        244,
        56
      ],
      "compactSize": [
        176,
        48
      ],
      "radius": "radii.button",
      "states": {
        "default": {
          "fill": "action.default",
          "text": "text.inverse",
          "contrast": 11.67
        },
        "hover": {
          "fill": "action.hover",
          "text": "text.inverse",
          "contrast": 14.51
        },
        "focusVisible": {
          "outline": "3px solid #006E70",
          "outlineOffset": 3
        },
        "disabled": {
          "fill": "action.disabled",
          "text": "text.inverse",
          "contrast": 4.82,
          "opacity": 0.72
        }
      }
    }
  },
  "contentConstraints": {
    "displayTitle": {
      "standard": {
        "maxLines": 2,
        "renderedRightEdgeMax": 688
      },
      "dense": {
        "maxLines": 3,
        "renderedRightEdgeMax": 688
      },
      "selectionRule": "use dense tier when standard would exceed two lines or safe-zone right edge"
    },
    "compactTitle": {
      "standard": {
        "maxLines": 2,
        "renderedRightEdgeMaxOffset": 304
      },
      "dense": {
        "maxLines": 3,
        "renderedRightEdgeMaxOffset": 304
      }
    },
    "venue": {
      "displayWideModeWidth": 608,
      "compactWidth": 304,
      "overflowPolicy": "wrap"
    },
    "badge": {
      "widthPolicy": "content-driven clamp",
      "compactMaxWidth": 144,
      "displayMaxWidth": 184
    }
  },
