      "role": "labels and supporting copy",
      "contrast_on_paper": 5.87
    },
    "text.inverse": {
      "value": "#FFFFFF",
      "role": "text on dark or accent surfaces"
    },
    "text.moduleMuted": {
      "value": "#BFD9DD",
      "role": "module labels",
      "contrast_on_module": 11.36
    },
    "border.neutral": {
      "value": "#BDB6AA",
      "role": "editorial rules"
    },
    "border.module": {
      "value": "#39405A",
      "role": "module rules"
    },
    "accent.coral": {
      "value": "#9F3424",
      "role": "in-person",
      "contrast_on_paper": 6.24,
      "white_text_contrast": 7.02
    },
    "accent.teal": {
      "value": "#006E70",
      "role": "hybrid",
      "contrast_on_paper": 5.39,
