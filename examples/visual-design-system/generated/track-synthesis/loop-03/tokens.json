{
  "schema": "loop-lab-event-card-tokens/1.1",
  "iteration": "synthesis-03",
  "description": "Density-aware Loop Lab event-card system. It preserves the protected editorial/signal zones and introduces width-aware metadata, title density tiers, and content-driven badges after a rendered compact venue overset in synthesis-01.",
  "source_lineage": [
    "synthesis-01"
  ],
  "changelog": [
    {
      "change": "components.metadataGrid compact and display flow",
      "reason": "synthesis-01 compact venue 'HUB A + WEB' rendered to x=779.358, 3.358px beyond its card edge x=776",
      "repair": "DATE and TIME occupy the first row; flexible VENUE receives a full-width second row in both compact and dense display modes"
    },
    {
      "change": "typography scale adds display.titleDense and compact.titleDense",
      "reason": "stress-test three-line event titles without per-instance arbitrary font scaling"
    },
    {
      "change": "formatBadge fixed widths replaced by measured width rules",
      "reason": "parent panel and synthesis-01 both retained fixed badge-width risk"
    }
  ],
  "color": {
